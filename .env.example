# ── Azure AI Foundry (LLM) ──────────────────────────────────────────────────
AZURE_AI_FOUNDRY_ENDPOINT=https://<resource>.services.ai.azure.com/openai/v1
AZURE_AI_FOUNDRY_API_KEY=

# ── MongoDB (session checkpointing + JWT storage) ────────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=agent_db

# ── Auth ──────────────────────────────────────────────────────────────────────
AUTH_JWT_SECRET=

# ── Mem0 (long-term memory, optional) ────────────────────────────────────────
MEM0_API_KEY=

# ── Agent SDK tuning ─────────────────────────────────────────────────────────
# All settings below can also be set with the AGENT_SDK_ prefix.
# See agent_sdk/config.py for the full list.
# AGENT_SDK_MAX_ITERATIONS=10
# AGENT_SDK_LLM_MODEL=gpt-5-nano
# AGENT_SDK_LLM_TEMPERATURE=0.7
# AGENT_SDK_LLM_TIMEOUT=120.0
# AGENT_SDK_LLM_MAX_RETRIES=3
# AGENT_SDK_TOOL_TIMEOUT=120.0

# ── Logging ───────────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO